rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUserProfile(data) {
      return data.phoneNumber is string && data.phoneNumber.size() <= 15 &&
             data.role in ['ADMIN', 'CENTER_OWNER', 'CENTER_OPERATOR', 'VERIFIED_USER', 'USER', 'GUEST'] &&
             data.isVerified is bool &&
             data.keys().hasAll(['phoneNumber', 'role', 'isVerified', 'createdAt']) &&
             data.keys().size() <= 10;
    }

    function isValidCenter(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             data.specialty is string &&
             data.isVerified is bool &&
             data.keys().hasAll(['name', 'ownerId', 'specialty', 'isVerified']) &&
             data.keys().size() <= 15;
    }

    function isValidAppointment(data) {
      return data.centerId is string &&
             data.userId == request.auth.uid &&
             data.status in ['PENDING', 'CONFIRMED', 'CANCELLED', 'COMPLETED'] &&
             data.keys().hasAll(['centerId', 'userId', 'date', 'time', 'status']) &&
             data.keys().size() <= 12;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && 
                       incoming().role in ['USER', 'GUEST'] && 
                       incoming().isVerified == false;
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'avatarUrl'])
      ) || isAdmin();
    }

    match /centers/{centerId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(centerId) && isValidCenter(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid)) && 
                       isValidCenter(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'specialty', 'location', 'services', 'imageUrl']);
      
      match /appointments/{appointmentId} {
        allow get: if isSignedIn() && (
          isOwner(resource.data.userId) || 
          isOwner(get(/databases/$(database)/documents/centers/$(centerId)).data.ownerId) ||
          isAdmin()
        );
        allow list: if isSignedIn() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/centers/$(centerId)).data.ownerId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isSignedIn() && isValidId(appointmentId) && isValidAppointment(incoming()) && 
                         incoming().status == 'PENDING';
        allow update: if isSignedIn() && (
          // User cancelling
          (isOwner(existing().userId) && incoming().status == 'CANCELLED' && 
           incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
          // Center owner/operator update status
          (isOwner(get(/databases/$(database)/documents/centers/$(centerId)).data.ownerId) && 
           incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
          isAdmin()
        );
      }
    }
  }
}
